# Postgres
DATABASE_URL=postgresql://kalshi:kalshi@localhost:5432/kalshi_ev

# Kalshi
KALSHI_API_BASE=https://demo-api.kalshi.co/trade-api/v2
KALSHI_KEY_ID=
KALSHI_PRIVATE_KEY=

# IPRoyal residential proxy
IPROYAL_PROXY_URL=http://USERNAME:PASSWORD@geo.iproyal.com:12321

# Scanner settings
INITIAL_BANKROLL_CENTS=80000
SCAN_INTERVAL_SECONDS=30
LOG_LEVEL=INFO

# Sharp-book floor for EV computation. Default 2 (robust devig-against-consensus).
# Set to 1 if you're temporarily running with a single sharp scraper online.
# MIN_SHARP_BOOKS=1
